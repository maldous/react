# Silence npm lifecycle banner on stdout.
# npm 10 writes the `> <pkg> <script>` banner to fd1 BEFORE the
# script body pipeline runs; inner-pipe filters cannot strip
# what npm wrote directly to stdout. Setting loglevel=silent
# here is required so `npm run v2:readiness:json` produces
# parseable JSON on stdout. Errors still propagate normally
# (silent only suppresses informational/banner output).
loglevel=silent
