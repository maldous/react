{
  "$comment": "ADR-0075 / ADR-ACT-0285 — machine-readable UI test contract. Declares product-intent UI surfaces so E2E survives visual redesigns. Tests drive off roles/capabilities/routes + accessible roles/names + declared data-testids ONLY; never CSS/DOM/position/incidental text. Validated by e2e:ui:contract:validate against admin nav (ADMIN_NAV_ITEMS), routes, and the clickthrough policy. migration: active|deprecated|removed (deprecated/removed require migrationNote).",
  "schemaVersion": 1,
  "globalPolicy": {
    "forbiddenBrittleSelectors": [
      "css-class:.*",
      "nth-child",
      "nth-of-type",
      ">",
      "xpath:",
      "text=exact-non-contractual",
      "position:",
      "breakpoint:"
    ],
    "preferredSelectors": [
      "role",
      "accessible-name",
      "data-testid(declared)",
      "route-metadata",
      "capability-metadata"
    ],
    "accessibilityBaseline": [
      "one-main-landmark",
      "meaningful-h1",
      "keyboard-reachable-controls",
      "logical-focus-order",
      "visible-focus",
      "accessible-names-on-controls",
      "labelled-forms",
      "announced-status-messages",
      "dialog-focus-trap-restore",
      "no-colour-only-meaning",
      "reduced-motion-safe"
    ],
    "observabilityBaseline": [
      "http.request.complete-on-load",
      "requestId-correlatable",
      "no-console-error",
      "no-pageerror",
      "no-failed-asset"
    ]
  },
