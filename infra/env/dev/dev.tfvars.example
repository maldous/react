# dev.tfvars.example — NON-SECRET config only. Copy to dev.tfvars (gitignored).
#
# Secrets are NOT stored in tfvars. They are supplied as TF_VAR_* environment
# variables sourced from .env.dev at apply time (`make keycloak-provision ENV=dev`):
#   TF_VAR_keycloak_admin_user       <- KEYCLOAK_ADMIN_USER
#   TF_VAR_keycloak_admin_password   <- KEYCLOAK_ADMIN_PASSWORD
#   TF_VAR_bff_client_secret         <- KEYCLOAK_CLIENT_SECRET
#   TF_VAR_provisioner_client_secret <- KEYCLOAK_PROVISIONER_CLIENT_SECRET
#   TF_VAR_fixture_user_password     <- KEYCLOAK_TEST_PASSWORD
# Never commit real secrets or the real dev.tfvars (ADR-0023/ADR-0044, constraint #8).

keycloak_url = "http://localhost:8090/kc"

# Realm
realm_name = "platform"

# keycloak_is_local=true: required to allow provision_fixture_users=true.
# Set true only when keycloak_url points to localhost or a Docker-internal address.
keycloak_is_local = true

# Fixture users — always true for dev environment
provision_fixture_users = true

# Keycloak hostname — determines token issuer (iss claim). Must match the public URL.
kc_hostname = "http://dev.localhost/kc"

# Apex domain for FQDN-based tenant routing (ADR-0029, ADR-0033).
apex_domain = "dev.localhost"
