# dev.tfvars.example — copy to dev.tfvars and fill in values (gitignored).
# dev.tfvars is listed in infra/.gitignore — never commit the real file.
#
# These values match the Docker Compose identity profile defaults (.env.example).
# Require: docker compose --profile identity up -d keycloak

# Keycloak admin credentials — matches KEYCLOAK_ADMIN_USER / KEYCLOAK_ADMIN_PASSWORD in compose.yaml
keycloak_url           = "http://localhost:8090/kc"
keycloak_admin_user    = "admin"
keycloak_admin_password = "admin"

# Realm
realm_name = "platform"

# BFF/API client secret — known dev-only value; not a real secret.
# The platform-api server reads this as KEYCLOAK_CLIENT_SECRET at runtime.
bff_client_secret = "local-dev-bff-secret"

# platform-provisioner service account secret — used by platform-api to create
# per-tenant Keycloak realms at runtime (POST /api/admin/tenants).
# Read at runtime as KEYCLOAK_PROVISIONER_CLIENT_SECRET.
provisioner_client_secret = "local-dev-provisioner-secret"

# keycloak_is_local=true: required to allow provision_fixture_users=true.
# Set true only when keycloak_url points to localhost or a Docker-internal address.
keycloak_is_local       = true

# Fixture users — always true for dev environment
provision_fixture_users = true

# Fixture user password — dev-only, not a real secret
fixture_user_password = "password"

# Keycloak hostname — determines token issuer (iss claim).
# Must match the public-facing URL:
#   Dev .localhost (Tilt / Compose with Caddy):  http://dev.localhost/kc
#   Test .localhost:                              http://test.localhost/kc
#   Production:                                  https://aldous.info/kc
kc_hostname = "http://dev.localhost/kc"

# Apex domain for FQDN-based tenant routing (ADR-0029, ADR-0033).
#   Dev .localhost:   dev.localhost
#   Test .localhost:  test.localhost
#   Production:       aldous.info
apex_domain = "dev.localhost"
