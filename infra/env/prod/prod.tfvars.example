# prod.tfvars.example — placeholder values only
# Copy to prod.tfvars and fill in real values (gitignored).
# Do not commit prod.tfvars — it contains secrets.
#
# ADR-0033: APEX_DOMAIN = aldous.info
#   KC_HOSTNAME = http://aldous.info/kc  (http for local; https when behind Cloudflare)
#
# After filling in values:
#   make compose-up-identity ENV=prod   # start Keycloak
#   make keycloak-provision ENV=prod    # apply Terraform

keycloak_url      = "http://localhost:8093/kc"
keycloak_realm    = "platform-production"

# Redirect URIs — must match what platform-api uses for KEYCLOAK_CALLBACK_URL
redirect_uris = ["http://aldous.info/auth/callback"]
web_origins   = ["http://aldous.info"]

# Keycloak frontend hostname (token issuer).
# Local prod-stack: http://aldous.info/kc
# Real Cloudflare deployment: https://aldous.info/kc
kc_hostname = "http://aldous.info/kc"

# Apex domain for FQDN-based tenant routing
apex_domain = "aldous.info"

# Provision fixture test users (true for local prod-stack E2E; false for real production)
provision_fixture_users = true

# Secrets — must match values used in platform-api and provisioner service
bff_client_secret         = "REPLACE_WITH_REAL_SECRET"
provisioner_client_secret = "REPLACE_WITH_REAL_SECRET"

keycloak_admin_user     = "admin"
keycloak_admin_password = "admin"

# Fixture user password (only used when provision_fixture_users = true)
fixture_user_password = "REPLACE_WITH_REAL_PASSWORD"
