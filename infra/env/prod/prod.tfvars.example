# prod.tfvars.example — placeholder values only
# Copy to prod.tfvars and fill in real values (gitignored).
# Do not commit prod.tfvars — it contains secrets.
#
# ADR-0033: APEX_DOMAIN = aldous.info
#   KC_HOSTNAME = https://aldous.info/kc  (https:// required for real production)
#
# After filling in values:
#   make compose-up-identity ENV=prod   # start Keycloak
#   make keycloak-provision ENV=prod    # apply Terraform
#
# Security notes:
#   - keycloak_url must be https:// or http://localhost (validated in main.tf)
#   - kc_hostname / redirect_uris / web_origins default to https:// in main.tf;
#     override to http:// only for local stack testing (no real TLS available)
#   - provision_fixture_users MUST remain false for apex_domain=aldous.info;
#     main.tf has a validation block that enforces this

keycloak_url      = "http://localhost:8093/kc"
keycloak_realm    = "platform-production"

# Use https:// for real production; http:// only for local stack testing
kc_hostname   = "https://aldous.info/kc"
redirect_uris = ["https://aldous.info/auth/callback"]
web_origins   = ["https://aldous.info"]

apex_domain = "aldous.info"

# Fixture users: permitted when keycloak_url is localhost (local stack only).
# MUST be false when keycloak_url points to a remote (real production) Keycloak.
# The validation in main.tf enforces this — setting true with a remote URL is rejected.
provision_fixture_users = false

# Secrets — must match values used in platform-api env and provisioner service
bff_client_secret         = "REPLACE_WITH_REAL_SECRET"
provisioner_client_secret = "REPLACE_WITH_REAL_SECRET"

keycloak_admin_user     = "REPLACE_WITH_ADMIN_USER"
keycloak_admin_password = "REPLACE_WITH_ADMIN_PASSWORD"

fixture_user_password = ""
