# development.tfvars.example ? copy to development.tfvars and fill in real values (gitignored).
# Do not commit real secrets.

keycloak_url              = "http://localhost:8090/kc"
keycloak_admin_user       = "admin"
keycloak_admin_password   = "admin"

realm_name = "platform-development"

bff_client_secret        = "change-me-to-a-real-secret"
provisioner_client_secret = "change-me-to-a-real-secret"

# Dev environment: use .localhost TLD (auto-resolves to 127.0.0.1 ? RFC 6761)
# For CI or shared hosts, override with the appropriate hostname.
kc_hostname = "http://dev.localhost/kc"
apex_domain = "dev.localhost"

# Set to true only for local/development to provision fixture users
provision_fixture_users = true
fixture_user_password   = "password"
