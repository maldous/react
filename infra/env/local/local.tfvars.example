# local.tfvars.example — placeholder values only
# Copy to local.tfvars and fill in real values (gitignored).
# Do not commit real secrets.

keycloak_url      = "http://localhost:8080"
keycloak_realm    = "platform-local"
keycloak_client   = "platform-spa-local"

# Environment-specific redirect URIs
redirect_uris  = ["http://localhost:5173/*"]
web_origins    = ["http://localhost:5173"]

# Set to true only for local/development to provision fixture users
provision_fixture_users = true
