# staging.tfvars.example — NON-SECRET config only. Copy to staging.tfvars (gitignored).
#
# Secrets are NOT stored in tfvars. They are supplied as TF_VAR_* environment
# variables sourced from .env.staging at apply time (`make keycloak-provision ENV=staging`):
#   TF_VAR_keycloak_admin_user       <- KEYCLOAK_ADMIN_USER
#   TF_VAR_keycloak_admin_password   <- KEYCLOAK_ADMIN_PASSWORD
#   TF_VAR_bff_client_secret         <- KEYCLOAK_CLIENT_SECRET
#   TF_VAR_provisioner_client_secret <- KEYCLOAK_PROVISIONER_CLIENT_SECRET
#   TF_VAR_fixture_user_password     <- KEYCLOAK_TEST_PASSWORD
# Never commit real secrets or the real staging.tfvars (ADR-0023/ADR-0044, constraint #8).
#
# ADR-0033: APEX_DOMAIN = staging.aldous.info, KC_HOSTNAME = https://staging.aldous.info/kc.

keycloak_url   = "http://localhost:8092/kc"
keycloak_realm = "platform-staging"

# Environment-specific redirect URIs.
redirect_uris = ["http://localhost:5173/*", "https://staging.aldous.info/auth/callback"]
web_origins   = ["http://localhost:5173", "https://staging.aldous.info"]

# Keycloak frontend hostname (determines token issuer). Behind Cloudflare: https.
kc_hostname = "https://staging.aldous.info/kc"

# Apex domain for FQDN-based tenant routing. Staging: *.staging.aldous.info.
apex_domain = "staging.aldous.info"

# keycloak_is_local gates provision_fixture_users; both stay false for remote staging.
keycloak_is_local       = false
provision_fixture_users = false
