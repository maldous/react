{
  "name": "react-platform",
  "version": "0.1.0",
  "description": "Local development and governance workspace for the enterprise React platform.",
  "type": "module",
  "exports": {
    "./package.json": "./package.json"
  },
  "architecture": {
    "schemaVersion": "1.0",
    "component": {
      "type": "application",
      "name": "react-platform",
      "system": "enterprise-react-platform",
      "domain": "architecture",
      "boundedContext": "workspace",
      "owner": "team-platform"
    },
    "lifecycle": {
      "stage": "stable",
      "role": "platform",
      "class": "stable.platform",
      "catalogLifecycle": "production",
      "visibility": "internal",
      "supportLevel": "standard",
      "reviewCadence": "on-change"
    },
    "governance": {
      "decisionRefs": [
        "ADR-0011",
        "ADR-0012",
        "ADR-0013"
      ],
      "semverPolicy": "internal-traceable",
      "changeControl": "owner-review",
      "promotionEligible": false
    },
    "runtime": {
      "production": false,
      "testOnly": true,
      "serviceName": "react-platform",
      "serviceNamespace": "workspace",
      "deploymentEnvironments": [
        "local",
        "development",
        "test"
      ]
    },
    "boundaries": {
      "publicExportsOnly": true,
      "deepImportsAllowed": false,
      "allowedConsumers": [
        "architecture"
      ],
      "forbiddenConsumers": [
        "domain",
        "contract",
        "adapter",
        "feature",
        "ui",
        "application"
      ]
    },
    "relations": {
      "dependsOn": [],
      "providesApis": [],
      "consumesApis": []
    },
    "tags": {
      "scope": "workspace",
      "type": "application",
      "stage": "stable",
      "role": "platform",
      "layer": "platform"
    },
    "readme": {
      "generated": true,
      "summary": "Monorepo workspace root for the enterprise React platform.",
      "responsibilities": [
        "Own workspace-wide scripts and developer workflows",
        "Coordinate app, package, and architecture tooling"
      ],
      "nonResponsibilities": [
        "Does not expose a runtime package API"
      ],
      "usage": [
        "npm run <script>"
      ],
      "operationalNotes": [
        "Workspace root is scanned by architecture validation."
      ]
    }
  },
  "private": true,
  "overrides": {
    "protobufjs": "^7.6.3"
  },
  "scripts": {
    "test": "node tools/run-tests.mjs",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "lint:md": "markdownlint-cli2 '**/*.md'",
    "lint": "eslint .",
    "knip": "./node_modules/.bin/knip",
    "depcruise": "./node_modules/.bin/depcruise --config .dependency-cruiser.cjs apps packages tools/architecture --output-type text",
    "audit:deps": "npm audit --audit-level=high --omit=dev",
    "audit:osv": "osv-scanner scan --recursive --config=osv-scanner.toml .",
    "secrets:scan": "command -v gitleaks >/dev/null 2>&1 || { echo 'gitleaks not found on PATH ? install from https://github.com/gitleaks/gitleaks/releases or use the gitleaks-action in CI'; exit 0; }; gitleaks detect --source .",
    "coverage:normalize": "node tools/coverage/normalize-lcov.mjs",
    "sbom:generate": "./node_modules/.bin/cyclonedx-npm --output-format JSON --output-file docs/evidence/security/sbom-baseline.json --package-lock-only --ignore-npm-errors",
    "compose:config": "docker compose config",
    "compose:up": "docker compose up -d",
    "compose:down": "docker compose down",
    "compose:logs": "docker compose logs -f",
    "compose:ps": "docker compose ps",
    "compose:identity": "docker compose --profile identity up -d keycloak",
    "compose:cloud": "docker compose --profile cloud-mocks up -d localstack",
