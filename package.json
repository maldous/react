{
  "private": true,
  "scripts": {
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "lint:md": "markdownlint-cli2 '**/*.md'",
    "lint": "eslint .",
    "knip": "knip",
    "depcruise": "depcruise --config .dependency-cruiser.cjs apps packages tools/architecture --output-type text",
    "audit:deps": "npm audit --audit-level=high",
    "audit:osv": "osv-scanner scan --recursive .",
    "secrets:scan": "command -v gitleaks >/dev/null 2>&1 && gitleaks detect --source . --no-git || echo 'gitleaks not found on PATH — install from https://github.com/gitleaks/gitleaks/releases or use the gitleaks-action in CI'",
    "sonar:scan": "SONAR_HOST_URL=http://localhost:9003 sonar-scanner",
    "sbom:generate": "cyclonedx-npm --output-format JSON --output-file docs/evidence/security/sbom-baseline.json --package-lock-only",
    "compose:config": "docker compose config",
    "compose:up": "docker compose up -d",
    "compose:down": "docker compose down",
    "compose:logs": "docker compose logs -f",
    "compose:ps": "docker compose ps",
    "compose:quality": "docker compose --profile quality up -d sonarqube",
    "compose:identity": "docker compose --profile identity up -d keycloak",
    "compose:cloud": "docker compose --profile cloud-mocks up -d localstack",
    "compose:sentry": "docker compose --profile sentry up -d",
    "tsc:check": "tsc --noEmit -p apps/react-enterprise-app/tsconfig.json",
    "test:compose": "node --test tests/integration/compose-smoke.test.mjs",
    "license:policy": "echo \"License policy: see docs/security/license-policy.md. Automated scanning tracked in ADR-ACT-0090.\"",
    "compose:config:all": "docker compose --profile quality --profile identity --profile cloud-mocks --profile sentry config",
    "compose:up:default": "docker compose up -d postgres redis clickhouse minio mailpit otel-collector",
    "compose:down:volumes": "docker compose down --volumes",
    "sonar:quality-gate": "SONAR_HOST_URL=http://localhost:9003 node tools/quality/sonar-quality-gate.mjs",
    "sonar:clean": "npm run sonar:scan && npm run sonar:quality-gate"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "3.1054.0",
    "@cyclonedx/cyclonedx-npm": "4.2.1",
    "@eslint/js": "10.0.1",
    "dependency-cruiser": "17.4.2",
    "eslint": "10.4.0",
    "globals": "17.6.0",
    "knip": "6.14.2",
    "markdownlint-cli2": "0.22.1",
    "nodemailer": "8.0.9",
    "pg": "8.14.1",
    "prettier": "3.8.3",
    "redis": "4.7.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.0"
  }
}
