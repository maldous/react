    "tsc:check:packages": "tsc --noEmit -p packages/tsconfig.packages.json",
    "test:compose": "node --loader ./apps/platform-api/loader.mjs --test tests/integration/compose-smoke.test.mjs",
    "license:policy": "license-checker-rseidelsohn --production --excludePrivatePackages --failOn 'GPL-2.0;GPL-3.0;AGPL-3.0;SSPL;Commons Clause' --out /dev/null && echo 'License scan passed — no blocked licenses found'",
    "compose:config:all": "docker compose --profile external-sonar --profile identity --profile cloud-mocks --profile external-sentry --profile observability --profile observability-provider --profile web --profile external-mocks --profile external-web --profile workflow-provider --profile pitr-provider --profile antivirus-provider config",
    "openapi:drift": "node tools/architecture/validate-openapi-drift/src/index.mjs .",
    "frontend:conventions": "node tools/architecture/validate-frontend-conventions/src/index.mjs",
    "usf:validate": "node tools/architecture/validate-universal-foundation/src/index.mjs",
