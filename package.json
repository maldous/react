{
  "private": true,
  "scripts": {
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "lint:md": "markdownlint-cli2 '**/*.md'",
    "lint": "eslint .",
    "knip": "knip",
    "depcruise": "depcruise --config .dependency-cruiser.cjs apps packages tools/architecture --output-type text",
    "audit:deps": "npm audit --audit-level=high",
    "audit:osv": "osv-scanner scan --recursive .",
    "secrets:scan": "command -v gitleaks >/dev/null 2>&1 && gitleaks detect --source . --no-git || echo 'gitleaks not found on PATH — install from https://github.com/gitleaks/gitleaks/releases or use the gitleaks-action in CI'"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "dependency-cruiser": "17.4.2",
    "eslint": "10.4.0",
    "globals": "17.6.0",
    "knip": "6.14.2",
    "markdownlint-cli2": "0.22.1",
    "prettier": "3.8.3",
    "typescript-eslint": "8.60.0"
  }
}
