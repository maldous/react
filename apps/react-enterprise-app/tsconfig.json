{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["node"],
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@platform/ui-design-system": ["../../packages/ui-design-system/src/index.ts"],
      "@platform/contracts-auth": ["../../packages/contracts-auth/src/index.ts"],
      "@platform/platform-errors": ["../../packages/platform-errors/src/index.ts"],
      "@platform/contracts-organisation": ["../../packages/contracts-organisation/src/index.ts"],
      "@platform/i18n-runtime": ["../../packages/i18n-runtime/src/index.ts"],
      "@platform/i18n-runtime/react": ["../../packages/i18n-runtime/src/react.ts"],
      "@platform/i18n-runtime/locales/en-GB.json": [
        "../../packages/i18n-runtime/locales/en-GB.json"
      ]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "dist", "src/**/*.test.ts", "src/**/*.test.tsx"]
}
