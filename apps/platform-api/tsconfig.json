{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "lib": ["ES2022"],
    "types": ["node"],
    "paths": {
      "@platform/api-runtime": ["../../packages/api-runtime/src/index.ts"],
      "@platform/platform-logging": ["../../packages/platform-logging/src/index.ts"],
      "@platform/platform-observability": ["../../packages/platform-observability/src/index.ts"],
      "@platform/platform-runtime-context": [
        "../../packages/platform-runtime-context/src/index.ts"
      ],
      "@platform/platform-errors": ["../../packages/platform-errors/src/index.ts"],
      "@platform/contracts-auth": ["../../packages/contracts-auth/src/index.ts"],
      "@platform/domain-identity": ["../../packages/domain-identity/src/index.ts"],
      "@platform/session-runtime": ["../../packages/session-runtime/src/index.ts"],
      "@platform/contracts-organisation": ["../../packages/contracts-organisation/src/index.ts"],
      "@platform/adapters-keycloak": ["../../packages/adapters-keycloak/src/index.ts"],
      "@platform/adapters-redis": ["../../packages/adapters-redis/src/index.ts"],
      "@platform/adapters-postgres": ["../../packages/adapters-postgres/src/index.ts"],
      "@platform/i18n-runtime": ["../../packages/i18n-runtime/src/index.ts"],
      "@platform/authorisation-runtime": ["../../packages/authorisation-runtime/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
