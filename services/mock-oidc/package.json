{
  "name": "@platform/mock-oidc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local/pre-real upstream OIDC identity-provider fixture (mock-google/mock-azure/mock-apple) brokered by Keycloak. NON-PRODUCTION.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
