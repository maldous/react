    "test": "node --experimental-strip-types --test src/*.test.ts"
  },
  "dependencies": {
    "express": "5.1.0",
    "oidc-provider": "8.8.1"
  },
  "devDependencies": {
    "@types/express": "5.0.0",
    "@types/node": "24.0.0",
    "@types/oidc-provider": "8.8.0",
    "typescript": "6.0.3"
  }
}
