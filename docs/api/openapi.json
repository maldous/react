{
  "openapi": "3.1.0",
  "info": {
    "title": "Enterprise Platform REST API",
    "version": "0.1.0",
    "description": "REST supplementary routes for the enterprise React platform BFF. GraphQL is the primary client boundary per ADR-0013; these routes cover health probes, auth, session management, FQDN-based tenant routing, per-tenant branding, auth settings self-service, and tenant provisioning. ADRs 0028–0031 govern the multi-tenant architecture."
  },
  "servers": [
    {
      "url": "http://localhost:3001",
      "description": "Local dev (platform-api)"
    },
    {
      "url": "https://aldous.info",
      "description": "Production (Cloudflare)"
    }
  ],
  "paths": {
    "/healthz": {
      "get": {
        "summary": "Process liveness probe",
        "operationId": "getHealth",
        "tags": ["Operations"],
        "responses": {
          "200": {
            "description": "Process is alive",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/readyz": {
      "get": {
        "summary": "Dependency readiness probe",
        "operationId": "getReadiness",
        "tags": ["Operations"],
        "responses": {
          "200": {
            "description": "All dependencies ready",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadinessResponse"
                }
              }
            }
          },
          "503": {
            "description": "One or more dependencies not ready",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadinessResponse"
                }
              }
            }
          }
        }
      }
    },
    "/version": {
      "get": {
        "summary": "Build version metadata",
        "operationId": "getVersion",
        "tags": ["Operations"],
        "responses": {
          "200": {
            "description": "Version info",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VersionResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/session": {
      "get": {
        "summary": "Get current session actor",
        "operationId": "getSession",
        "tags": ["Auth"],
        "responses": {
          "200": {
            "description": "Authenticated session actor",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionActor"
                }
              }
            }
          },
          "401": {
            "description": "No active session",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/graphql": {
      "post": {
        "summary": "GraphQL application boundary",
        "operationId": "graphql",
        "tags": ["GraphQL"],
        "responses": {
          "200": {
            "description": "GraphQL response"
          },
          "400": {
            "description": "Invalid GraphQL query or operation",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthenticated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/admin/logs/search": {
      "get": {
        "summary": "Search operator logs",
        "operationId": "adminLogsSearch",
        "tags": ["Admin Logs"],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Free-text search query"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 1000,
              "default": 100
            },
            "description": "Maximum number of entries to return"
          },
          {
            "name": "direction",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["forward", "backward"],
              "default": "backward"
            },
            "description": "Pagination direction"
          }
        ],
        "responses": {
          "200": {
            "description": "Matching log entries"
          },
          "401": {
            "description": "Unauthenticated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/auth/login": {
      "get": {
        "summary": "Initiate OAuth 2.0 Authorization Code + PKCE login",
        "operationId": "authLogin",
        "tags": ["Auth"],
        "parameters": [
          {
            "name": "returnTo",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Relative path to redirect to after successful login"
          }
        ],
        "responses": {
          "302": {
            "description": "Redirect to Keycloak authorization endpoint"
          },
          "400": {
            "description": "Invalid request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/auth/callback": {
      "get": {
        "summary": "OAuth 2.0 Authorization Code callback",
        "operationId": "authCallback",
        "tags": ["Auth"],
        "parameters": [
          {
            "name": "code",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "state",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "302": {
            "description": "Redirect to app after session creation"
          },
          "400": {
            "description": "Invalid state, code, or missing pre-auth cookie",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unverified or absent email",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Email already registered under a different identity provider",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "502": {
            "description": "Token exchange or userinfo call failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "summary": "Destroy server-side session and clear cookie",
        "operationId": "authLogout",
        "tags": ["Auth"],
        "responses": {
          "204": {
            "description": "Session destroyed, cookie cleared"
          }
        }
      }
    },
    "/api/organisation/profile": {
      "get": {
        "summary": "Get the authenticated user's organisation profile",
        "operationId": "getOrganisationProfile",
        "tags": ["Organisation"],
        "security": [
          {
            "sessionCookie": []
          }
        ],
        "responses": {
          "200": {
            "description": "Organisation profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrganisationProfile"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ValidationError"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "patch": {
        "summary": "Update the organisation display name",
        "operationId": "patchOrganisationProfile",
        "tags": ["Organisation"],
        "security": [
          {
            "sessionCookie": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateOrganisationProfileRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated organisation profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OrganisationProfile"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ValidationError"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/internal/auth/forward": {
      "get": {
        "summary": "Caddy forward_auth gate — internal only",
        "operationId": "forwardAuth",
        "tags": ["Internal"],
        "description": "Called by Caddy before proxying admin/tool UIs. NOT externally reachable — blocked in Caddyfile public blocks. Requires X-Internal-Secret header. Returns 200 (allow), 401 (no session), 403 (forbidden), or 503 (misconfigured). ADR-0029, ADR-0030, ADR-0031.",
        "parameters": [
          {
            "name": "resource",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "admin:sonarqube"
          },
          {
            "name": "scope",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "default": "read"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Access granted"
          },
          "401": {
            "description": "No session"
          },
          "403": {
            "description": "Denied"
          },
          "503": {
            "description": "Secret not configured"
          }
        }
      }
    },
    "/api/auth/providers": {
      "get": {
        "summary": "Brokered login providers",
        "operationId": "getAuthProviders",
        "tags": ["Auth"],
        "description": "Unauthenticated. Lists the enabled login options the React /login selector should render (platform plus any enabled brokered third-party providers). Environment/mode aware; contains no secrets. Each item links to the BFF handoff /auth/login?provider=. ADR-ACT-0157.",
        "responses": {
          "200": {
            "description": "Enabled login providers",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": {
                        "type": "string"
                      },
                      "label": {
                        "type": "string"
                      },
                      "type": {
                        "type": "string",
                        "enum": ["oidc", "keycloak"]
                      },
                      "loginUrl": {
                        "type": "string"
                      },
                      "enabled": {
                        "type": "boolean"
                      },
                      "mode": {
                        "type": "string",
                        "enum": ["mock", "real", "internal"]
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/theme": {
      "get": {
        "summary": "Per-tenant branding configuration",
        "operationId": "getTheme",
        "tags": ["Tenant"],
        "description": "Returns theme config (logo, colours, displayName) resolved from the tenant schema via Host header. Falls back to platform defaults if tenant not found or schema not seeded. ADR-0029 §4.",
        "responses": {
          "200": {
            "description": "Theme config",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "displayName": {
                      "type": "string"
                    },
                    "primaryColour": {
                      "type": "string"
                    },
                    "logoUrl": {
                      "type": ["string", "null"]
                    },
                    "faviconUrl": {
                      "type": ["string", "null"]
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/settings/idps": {
      "get": {
        "summary": "List tenant identity providers",
        "operationId": "listIdps",
        "tags": ["Auth Settings"],
        "description": "Returns configured IdPs for the tenant realm derived from the Host header. Requires admin.access permission. ADR-0030 §1b.",
        "security": [
          {
            "sessionCookie": []
          }
        ],
        "responses": {
          "200": {
            "description": "IdP list"
          },
          "400": {
            "description": "No tenant context"
          },
          "403": {
            "description": "Forbidden"
          }
        }
      },
      "post": {
        "summary": "Create or update identity provider",
        "operationId": "upsertIdp",
        "tags": ["Auth Settings"],
        "description": "Creates or updates an IdP in the tenant Keycloak realm. Realm derived from Host header — never from body. ADR-0030 §1b.",
        "security": [
          {
            "sessionCookie": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["alias", "displayName", "providerId"],
                "properties": {
                  "alias": {
                    "type": "string"
                  },
                  "displayName": {
                    "type": "string"
                  },
                  "providerId": {
                    "type": "string",
                    "enum": ["oidc", "saml", "keycloak-oidc"]
                  },
                  "config": {
                    "type": "object"
                  },
                  "enabled": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Updated"
          },
          "400": {
            "description": "Validation error"
          },
          "403": {
            "description": "Forbidden"
          }
        }
      }
    },
    "/api/auth/settings/mfa": {
      "get": {
        "summary": "Get MFA policy",
        "operationId": "getMfaPolicy",
        "tags": ["Auth Settings"],
        "security": [
          {
            "sessionCookie": []
          }
        ],
        "responses": {
          "200": {
            "description": "MFA policy"
          }
        }
      },
      "patch": {
        "summary": "Set MFA policy",
        "operationId": "setMfaPolicy",
        "tags": ["Auth Settings"],
        "security": [
          {
            "sessionCookie": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["required"],
                "properties": {
                  "required": {
                    "type": "string",
                    "enum": ["none", "optional", "required"]
                  },
                  "type": {
                    "type": "string",
                    "enum": ["totp", "webauthn"]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Updated"
          },
          "400": {
            "description": "Validation error"
          }
        }
      }
    },
    "/api/auth/settings/session": {
      "get": {
        "summary": "Get session policy",
        "operationId": "getSessionPolicy",
        "tags": ["Auth Settings"],
        "security": [
          {
            "sessionCookie": []
          }
        ],
        "responses": {
          "200": {
            "description": "Session policy"
          }
        }
      },
      "patch": {
        "summary": "Set session policy",
        "operationId": "setSessionPolicy",
        "tags": ["Auth Settings"],
        "security": [
          {
            "sessionCookie": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Updated"
          }
        }
      }
    },
    "/api/auth/settings/sysadmin-brokering": {
      "get": {
        "summary": "Get sysadmin brokering config",
        "operationId": "getSysadminBrokering",
        "tags": ["Auth Settings"],
        "security": [
          {
            "sessionCookie": []
          }
        ],
        "responses": {
          "200": {
            "description": "Brokering config"
          }
        }
      },
      "patch": {
        "summary": "Set sysadmin brokering config",
        "operationId": "setSysadminBrokering",
        "tags": ["Auth Settings"],
        "security": [
          {
            "sessionCookie": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["enabled"],
                "properties": {
                  "enabled": {
                    "type": "boolean"
                  },
                  "requireMfa": {
                    "type": "boolean"
                  },
                  "auditAllAccess": {
                    "type": "boolean"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Updated"
          }
        }
      }
    },
    "/api/admin/tenants": {
      "post": {
        "summary": "Provision a new tenant",
        "operationId": "createTenant",
        "tags": ["Admin"],
        "description": "Provisions all tenant infrastructure: PostgreSQL schema, Keycloak realm, Redis ACL user, S3 bucket policy. Per-resource tiers configurable (shared/dedicated/external/air-gapped). System-admin only. ADR-0029, ADR-0031.",
        "security": [
          {
            "sessionCookie": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["slug", "displayName", "adminEmail"],
                "properties": {
                  "slug": {
                    "type": "string"
                  },
                  "displayName": {
                    "type": "string"
                  },
                  "adminEmail": {
                    "type": "string",
                    "format": "email"
                  },
                  "resources": {
                    "type": "object",
                    "description": "Per-resource tier configuration. Defaults to shared for all resources if omitted."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Tenant provisioned"
          },
          "400": {
            "description": "Validation error"
          },
          "409": {
            "description": "Slug already taken"
          }
        }
      }
    },
    "/api/admin/tenants/resources": {
      "get": {
        "summary": "Get tenant resource config",
        "operationId": "getTenantResources",
        "tags": ["Admin"],
        "description": "Returns the per-resource tier configuration for the specified tenant. System-admin only. ADR-0031.",
        "security": [
          {
            "sessionCookie": []
          }
        ],
        "parameters": [
          {
            "name": "organisationId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Resource config"
          },
          "404": {
            "description": "Tenant not found"
          }
        }
      }
    },
    "/api/admin/sub-tenants": {
      "post": {
        "summary": "Provision a sub-tenant (not yet implemented)",
        "operationId": "createSubTenant",
        "tags": ["Admin"],
        "description": "Hierarchical tenant provisioning — tracked in ADR-ACT-0143. Returns 501 until implemented.",
        "security": [
          {
            "sessionCookie": []
          }
        ],
        "responses": {
          "501": {
            "description": "Not yet implemented"
          }
        }
      }
    },
    "/api/admin/support-session": {
      "post": {
        "summary": "Create system-admin support session",
        "operationId": "admin.support-session.create",
        "tags": ["Admin"],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SupportSessionRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Support session created"
          },
          "400": {
            "description": "Validation error"
          },
          "401": {
            "description": "Unauthenticated"
          },
          "403": {
            "description": "Forbidden"
          }
        }
      }
    },
    "/api/auth/settings/resource-policies": {
      "get": {
        "summary": "List resource policies",
        "operationId": "auth.settings.resource-policies.list",
        "tags": ["Auth Settings"],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Resource policy list"
          },
          "401": {
            "description": "Unauthenticated"
          },
          "403": {
            "description": "Forbidden"
          },
          "503": {
            "description": "No credential configured"
          }
        }
      },
      "patch": {
        "summary": "Set resource policy",
        "operationId": "auth.settings.resource-policies.set",
        "tags": ["Auth Settings"],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "204": {
            "description": "Resource policy updated"
          },
          "400": {
            "description": "Validation error"
          },
          "401": {
            "description": "Unauthenticated"
          },
          "403": {
            "description": "Forbidden"
          },
          "503": {
            "description": "No credential configured"
          }
        }
      }
    },
    "/api/auth/settings/domains": {
      "post": {
        "summary": "Add vanity domain",
        "operationId": "auth.settings.domains.add",
        "tags": ["Auth Settings"],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "201": {
            "description": "Domain added"
          },
          "400": {
            "description": "Validation error"
          },
          "401": {
            "description": "Unauthenticated"
          },
          "403": {
            "description": "Forbidden"
          },
          "503": {
            "description": "No credential configured"
          }
        }
      }
    },
    "/api/auth/settings/domains/:domain": {
      "delete": {
        "summary": "Remove vanity domain",
        "operationId": "auth.settings.domains.remove",
        "tags": ["Auth Settings"],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "parameters": [
          {
            "name": "domain",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Domain removed"
          },
          "401": {
            "description": "Unauthenticated"
          },
          "403": {
            "description": "Forbidden"
          },
          "503": {
            "description": "No credential configured"
          }
        }
      }
    },
    "/api/auth/settings/domains/challenges": {
      "post": {
        "summary": "Create domain ownership challenge",
        "operationId": "auth.settings.domains.challenge.create",
        "tags": ["Auth Settings"],
        "security": [
          {
            "cookieAuth": []
          }
        ],
        "responses": {
          "201": {
            "description": "Challenge created"
          },
          "400": {
            "description": "Invalid domain"
          },
