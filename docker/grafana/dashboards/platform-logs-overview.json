{
  "dashboard": {
    "uid": "platform-logs-overview",
    "title": "Platform Logs Overview",
    "tags": ["platform", "logs", "loki"],
    "timezone": "browser",
    "schemaVersion": 39,
    "refresh": "30s",
    "version": 1,
    "description": "Platform enterprise log overview — errors, warnings, request rates, slow requests, and tenant/operation breakdowns.",
    "panels": [
      {
        "collapsed": false,
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
        "id": 100,
        "title": "Error & Warning Rates",
        "type": "row"
      },
      {
        "datasource": { "type": "loki", "uid": "platform-loki" },
        "fieldConfig": {
          "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2 } }
        },
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
        "id": 1,
        "title": "Error Logs by Service",
        "type": "timeseries",
        "targets": [
          {
            "datasource": { "type": "loki", "uid": "platform-loki" },
            "expr": "sum by (service) (count_over_time({platform=\"enterprise-react-platform\", level=~\"error|fatal\"} | json [$__interval]))",
            "legendFormat": "{{service}} errors",
            "refId": "A"
          }
        ]
      },
      {
        "datasource": { "type": "loki", "uid": "platform-loki" },
        "fieldConfig": {
          "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 1 } }
        },
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
        "id": 2,
        "title": "Warning Logs by Service",
        "type": "timeseries",
        "targets": [
          {
            "datasource": { "type": "loki", "uid": "platform-loki" },
            "expr": "sum by (service) (count_over_time({platform=\"enterprise-react-platform\", level=\"warn\"} | json [$__interval]))",
            "legendFormat": "{{service}} warnings",
            "refId": "A"
          }
        ]
      },
      {
        "collapsed": false,
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
        "id": 101,
        "title": "Request Performance",
        "type": "row"
      },
      {
        "datasource": { "type": "loki", "uid": "platform-loki" },
        "fieldConfig": { "defaults": { "unit": "ms" } },
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
        "id": 3,
        "title": "Slow Requests (>1s)",
        "type": "logs",
        "targets": [
          {
            "datasource": { "type": "loki", "uid": "platform-loki" },
            "expr": "{platform=\"enterprise-react-platform\", service=\"platform-api\"} | json | durationMs > 1000 | line_format \"{{.operationName}} {{.durationMs}}ms\"",
            "refId": "A"
          }
        ]
      },
      {
        "datasource": { "type": "loki", "uid": "platform-loki" },
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
        "id": 4,
        "title": "Top Failing Routes",
        "type": "barchart",
        "targets": [
          {
            "datasource": { "type": "loki", "uid": "platform-loki" },
            "expr": "topk(10, sum by (path) (count_over_time({platform=\"enterprise-react-platform\", service=\"platform-api\", level=~\"error|fatal\"} | json [$__interval])))",
            "legendFormat": "{{path}}",
            "refId": "A"
          }
        ]
      },
      {
        "collapsed": false,
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
        "id": 102,
        "title": "Recent Errors & Fatals",
        "type": "row"
      },
      {
        "datasource": { "type": "loki", "uid": "platform-loki" },
        "gridPos": { "h": 10, "w": 24, "x": 0, "y": 19 },
        "id": 5,
        "title": "Recent Fatal/Error Logs",
        "type": "logs",
        "targets": [
          {
            "datasource": { "type": "loki", "uid": "platform-loki" },
            "expr": "{platform=\"enterprise-react-platform\", level=~\"error|fatal\"} | json",
            "refId": "A"
          }
        ]
      },
      {
        "collapsed": false,
        "gridPos": { "h": 1, "w": 24, "x": 0, "y": 29 },
        "id": 103,
        "title": "Tenant & Operation Breakdown",
        "type": "row"
      },
      {
        "datasource": { "type": "loki", "uid": "platform-loki" },
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 30 },
        "id": 6,
        "title": "Errors by Tenant",
        "type": "timeseries",
        "targets": [
          {
            "datasource": { "type": "loki", "uid": "platform-loki" },
            "expr": "sum by (tenantId) (count_over_time({platform=\"enterprise-react-platform\", service=\"platform-api\", level=~\"error|fatal\"} | json | tenantId != \"\" [$__interval]))",
            "legendFormat": "{{tenantId}}",
            "refId": "A"
          }
        ]
      },
      {
        "datasource": { "type": "loki", "uid": "platform-loki" },
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 30 },
        "id": 7,
        "title": "Errors by Operation",
        "type": "barchart",
        "targets": [
          {
            "datasource": { "type": "loki", "uid": "platform-loki" },
            "expr": "sum by (operationName) (count_over_time({platform=\"enterprise-react-platform\", service=\"platform-api\", level=~\"error|fatal\"} | json | operationName != \"\" [$__interval]))",
            "legendFormat": "{{operationName}}",
            "refId": "A"
          }
        ]
      }
    ],
    "templating": {
      "list": [
        {
          "current": {},
          "datasource": { "type": "loki", "uid": "platform-loki" },
          "definition": "label_values(service)",
          "hide": 0,
          "includeAll": true,
          "multi": true,
          "name": "service",
          "options": [],
          "query": "label_values(service)",
          "refresh": 2,
          "sort": 1,
          "type": "query",
          "label": "Service"
        },
        {
          "current": {},
          "datasource": { "type": "loki", "uid": "platform-loki" },
          "definition": "label_values(level)",
          "hide": 0,
          "includeAll": true,
          "multi": true,
          "name": "level",
          "options": [],
          "query": "label_values(level)",
          "refresh": 2,
          "sort": 1,
          "type": "query",
          "label": "Level"
        }
      ]
    },
    "time": { "from": "now-1h", "to": "now" }
  }
}
