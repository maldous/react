{
  "dashboard": {
    "uid": "platform-overview",
    "title": "Platform Overview",
    "tags": ["platform", "v1c-17b"],
    "timezone": "browser",
    "schemaVersion": 39,
    "version": 2,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "HTTP Requests (rate)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "platform-prometheus" },
            "refId": "A",
            "expr": "rate(http_requests_total[5m])",
            "legendFormat": "{{method}} {{route}} ({{status_class}})"
          }
        ]
      },
      {
        "id": 2,
        "title": "Platform API Uptime",
        "type": "stat",
        "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "platform-prometheus" },
            "refId": "A",
            "expr": "up{job=\"platform-api\"}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "red", "value": null },
                { "color": "green", "value": 0 }
              ]
            },
            "mappings": [
              { "type": "value", "value": "1", "text": "UP" },
              { "type": "value", "value": "0", "text": "DOWN" }
            ]
          }
        }
      },
      {
        "id": 3,
        "title": "HTTP Error Rate (5xx)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "platform-prometheus" },
            "refId": "A",
            "expr": "rate(http_requests_total{status_class=\"5xx\"}[5m])",
            "legendFormat": "5xx errors"
          }
        ]
      },
      {
        "id": 4,
        "title": "HTTP Duration (p95)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "platform-prometheus" },
            "refId": "A",
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "{{method}} {{route}}"
          }
        ]
      },
      {
        "id": 5,
        "title": "HTTP Duration (avg)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "platform-prometheus" },
            "refId": "A",
            "expr": "rate(http_request_duration_seconds_sum[5m]) / rate(http_request_duration_seconds_count[5m])",
            "legendFormat": "{{method}} {{route}}"
          }
        ]
      },
      {
        "id": 6,
        "title": "Postgres Availability",
        "type": "stat",
        "gridPos": { "h": 4, "w": 4, "x": 12, "y": 4 },
        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "platform-prometheus" },
            "refId": "A",
            "expr": "postgres_available"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "red", "value": null },
                { "color": "green", "value": 0 }
              ]
            },
            "mappings": [
              { "type": "value", "value": "1", "text": "UP" },
              { "type": "value", "value": "0", "text": "DOWN" }
            ]
          }
        }
      },
      {
        "id": 7,
        "title": "Redis Availability",
        "type": "stat",
        "gridPos": { "h": 4, "w": 4, "x": 16, "y": 4 },
        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "platform-prometheus" },
            "refId": "A",
            "expr": "redis_available"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "red", "value": null },
                { "color": "green", "value": 0 }
              ]
            },
            "mappings": [
              { "type": "value", "value": "1", "text": "UP" },
              { "type": "value", "value": "0", "text": "DOWN" }
            ]
          }
        }
      },
      {
        "id": 8,
        "title": "Auth Denials (4xx)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "platform-prometheus" },
            "refId": "A",
            "expr": "rate(http_requests_total{status_class=\"4xx\"}[5m])",
            "legendFormat": "{{route}}"
          }
        ]
      },
      {
        "id": 9,
        "title": "Event Bus Pending",
        "type": "stat",
        "gridPos": { "h": 4, "w": 4, "x": 16, "y": 8 },
        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "platform-prometheus" },
            "refId": "A",
            "expr": "event_bus_pending"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 100 },
                { "color": "red", "value": 1000 }
              ]
            }
          }
        }
      },
      {
        "id": 10,
        "title": "Dead Letter Count",
        "type": "stat",
        "gridPos": { "h": 4, "w": 4, "x": 20, "y": 8 },
        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "platform-prometheus" },
            "refId": "A",
            "expr": "dead_letter_count"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "green", "value": null },
                { "color": "red", "value": 1 }
              ]
            }
          }
        }
      },
      {
        "id": 11,
        "title": "Worker Liveness",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 24 },
        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "platform-prometheus" },
            "refId": "A",
            "expr": "worker_liveness"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "red", "value": null },
                { "color": "green", "value": 0 }
              ]
            },
            "mappings": [
              { "type": "value", "value": "1", "text": "ALIVE" },
              { "type": "value", "value": "0", "text": "DEAD" }
            ]
          }
        }
      },
      {
        "id": 12,
        "title": "Scheduled Job Outcomes",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 6, "y": 24 },
        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "platform-prometheus" },
            "refId": "A",
            "expr": "rate(scheduled_job_outcome_total[5m])",
            "legendFormat": "{{job_key}} {{outcome}}"
          }
        ]
      },
      {
        "id": 13,
        "title": "Notification Dispatches",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "platform-prometheus" },
            "refId": "A",
            "expr": "rate(notification_dispatch_total[5m])",
            "legendFormat": "{{channel}} {{outcome}}"
          }
        ]
      },
      {
        "id": 14,
        "title": "Provider Readiness",
        "type": "table",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "platform-prometheus" },
            "refId": "A",
            "expr": "provider_readiness"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "red", "value": null },
                { "color": "green", "value": 0 }
              ]
            },
            "mappings": [
              { "type": "value", "value": "1", "text": "Ready" },
              { "type": "value", "value": "0", "text": "Not Ready" }
            ]
          }
        }
      }
    ]
  }
}
