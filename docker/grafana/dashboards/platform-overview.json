{
  "dashboard": {
    "uid": "platform-overview",
    "title": "Platform Overview",
    "tags": ["platform", "v1c-17b"],
    "timezone": "browser",
    "schemaVersion": 39,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "HTTP Requests (rate)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "refId": "A",
            "expr": "rate(http_requests_total[5m])",
            "legendFormat": "{{method}} {{route_template}} ({{status_code}})"
          }
        ]
      },
      {
        "id": 2,
        "title": "Platform API Uptime",
        "type": "stat",
        "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
        "targets": [{ "refId": "A", "expr": "up{job=\"platform-api\"}" }],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "red", "value": null },
                { "color": "green", "value": 0 }
              ]
            },
            "mappings": [
              { "type": "value", "value": "1", "text": "UP" },
              { "type": "value", "value": "0", "text": "DOWN" }
            ]
          }
        }
      },
      {
        "id": 3,
        "title": "HTTP Error Rate",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          {
            "refId": "A",
            "expr": "rate(http_requests_total{status_code=~\"5..\"}[5m])",
            "legendFormat": "5xx errors"
          }
        ]
      },
      {
        "id": 4,
        "title": "HTTP Duration (p95)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "targets": [
          {
            "refId": "A",
            "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
            "legendFormat": "{{method}} {{route_template}}"
          }
        ]
      }
    ]
  }
}
