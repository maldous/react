# docker/caddy/Caddyfile
#
# Two virtual hosts:
#   aldous.info        — super-global admin console + all developer/operational UIs
#   *.aldous.info      — per-tenant application + tenant-scoped admin UIs
#
# TLS termination: Cloudflare handles HTTPS; Caddy listens on :80.
# Forward auth: all admin/tool routes check session via platform-api before proxying.
#
# ADR-0022: BFF owns session exchange and auth routes.
# ADR-0029: FQDN-based tenant routing; path-prefixed tool access.
# ADR-0030: forward_auth enforces Keycloak UMA resource policies on all tool routes.

# ---------------------------------------------------------------------------
# Forward auth snippet — reusable across all protected tool routes.
# platform-api returns 200 (allow), 401 (no session), or 403 (forbidden).
# Caddy copies the Cookie header so platform-api can read the session.
# ---------------------------------------------------------------------------
# X-Internal-Secret prevents external callers from reaching /internal/auth/forward.
# Set CADDY_INTERNAL_SECRET in the environment; platform-api validates it.
# /internal/* is NOT exposed in the public virtual host blocks below — this is
# defence in depth: the route simply doesn't exist externally, and the secret
# provides a second check in case of future misconfiguration.
(forward_auth_check) {
	forward_auth platform-api:3001 {
		uri /internal/auth/forward?resource={args[0]}&scope={args[1]}
		copy_headers Cookie
		header_up X-Forwarded-Host {host}
		header_up X-Internal-Secret {$CADDY_INTERNAL_SECRET}
	}
}

# ---------------------------------------------------------------------------
# Super-global admin — aldous.info (and localhost for local E2E without /etc/hosts)
# Hosts the platform admin SPA, all developer tooling, and operational UIs.
# http://localhost allows make all to run e2e-web-smoke without /etc/hosts.
# http://aldous.info handles production (via Cloudflare) and dev with /etc/hosts.
# ---------------------------------------------------------------------------
http://aldous.info http://localhost {
	# Keycloak — all realms accessible (super-admin console + tenant realm access)
	handle /kc/* {
		import forward_auth_check admin:keycloak read
		reverse_proxy keycloak:8080
	}

	# Mailpit — all tenant email capture (dev only; graceful 502 if not running)
	handle /mailpit/* {
		import forward_auth_check admin:mailpit read
		uri strip_prefix /mailpit
		reverse_proxy mailpit:8025
	}

	# SonarQube — code quality dashboard
	handle /sonar/* {
		import forward_auth_check admin:sonarqube read
		reverse_proxy sonarqube:9000
	}

	# MinIO — object storage console
	handle /minio/* {
		import forward_auth_check admin:minio read
		reverse_proxy minio:9001
	}

	# Sentry — error and performance monitoring dashboard
	handle /sentry/* {
		import forward_auth_check admin:sentry read
		uri strip_prefix /sentry
		reverse_proxy sentry-web:9000
	}

	# WireMock — external HTTP mock admin (dev only)
	handle /wiremock/* {
		import forward_auth_check admin:wiremock read
		uri strip_prefix /wiremock
		reverse_proxy wiremock:8080
	}

	# ClickHouse — analytics HTTP play UI
	handle /clickhouse/* {
		import forward_auth_check admin:clickhouse read
		uri strip_prefix /clickhouse
		reverse_proxy clickhouse:8123
	}

	# LocalStack — cloud mock (dev/staging only)
	handle /localstack/* {
		import forward_auth_check admin:localstack read
		uri strip_prefix /localstack
		reverse_proxy localstack:4566
	}

	# Tilt UI cannot be path-proxied (its SPA makes absolute /api/* calls).
	# Access Tilt directly at http://localhost:10350 during local development.
	# The Tiltfile exposes a direct link on the platform-api resource.

	# BFF — platform admin API
	# NOTE: /internal/* is intentionally NOT listed here — it must not be
	# externally reachable. Caddy calls platform-api:3001/internal/* directly
	# via the forward_auth directive (Docker-internal network only).
	handle /api/* {
		reverse_proxy platform-api:3001
	}
	handle /auth/* {
		reverse_proxy platform-api:3001
	}
	handle /healthz {
		reverse_proxy platform-api:3001
	}
	handle /readyz {
		reverse_proxy platform-api:3001
	}
	handle /version {
		reverse_proxy platform-api:3001
	}

	# Super-admin React SPA (platform admin console)
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}

# ---------------------------------------------------------------------------
# Per-tenant — {slug}.aldous.info
# Each subdomain routes to the tenant's Keycloak realm and application.
# Tenant-scoped admin UIs are path-prefixed here with tenant-filtered access.
# ---------------------------------------------------------------------------
http://*.aldous.info {
	# Keycloak — tenant-specific realm admin console
	handle /kc/* {
		import forward_auth_check admin:keycloak read
		reverse_proxy keycloak:8080
	}

	# Mailpit — tenant-domain-filtered email view
	# platform-api forward auth verifies the user belongs to this tenant
	# and only shows emails addressed to @{slug}.aldous.info.
	handle /mailpit/* {
		import forward_auth_check admin:mailpit read
		uri strip_prefix /mailpit
		reverse_proxy mailpit:8025
	}

	# Sentry — tenant project scoped view
	handle /sentry/* {
		import forward_auth_check admin:sentry read
		uri strip_prefix /sentry
		reverse_proxy sentry-web:9000
	}

	# BFF — /internal/* intentionally NOT listed (same reason as aldous.info block above)
	handle /api/* {
		reverse_proxy platform-api:3001
	}
	handle /auth/* {
		reverse_proxy platform-api:3001
	}
	handle /healthz {
		reverse_proxy platform-api:3001
	}
	handle /readyz {
		reverse_proxy platform-api:3001
	}
	handle /version {
		reverse_proxy platform-api:3001
	}

	# Tenant React SPA
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
