!tools/coverage/

# Caches and temporary files
.tmp/
.cache/
.scannerwork/
.next/
.vite/
.turbo/
.nx/cache/

# Generated operational reports
reports/**

# Local + generated environment files (ADR-0072 / ADR-0069 — re-asserted by
# ADR-ACT-0305). OpenBao (ADR-0069, openbao/openbao:2.2.0) is the central runtime
# secret store; runtime env artifacts are generated at .env/<target>.env and
# .env/secrets/<target>.env by `make env-generate-runtime` once a stage is
# bootstrapped. The tracked source of truth is config/environments/*.json
# (per-stage manifests + common.json + shared.json for Sonar/Sentry). There is
# NO hand-maintained env file of any kind — .env, .env.<stage>, .env.example,
# .env.sonar, .env.sentry. Everything below is gitignored, reproducible,
# secret-bearing, and NEVER committed (CLAUDE.md constraint #8).
#
# Explicit guards over .env.* so a hand-added slip cannot land:
.env                          # the env-as-file root/subdir case
.env.example                   # onboarding template — generated, not committed
/.env/                        # runtime env artifact directory (anchor at root)
.env.*


# OS/editor noise
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# Session memory buffer (tool-local, not project state)
.remember/
# Local generated artifact workspaces
/adr-work-*/

# Generated handoff artifacts
/adr-artifacts-*.zip
/adr-*-report-*.md

# Generated tool self-evidence accidentally emitted inside test fixtures
/tools/architecture/**/tests/fixtures/**/reports/tooling/**

# Playwright E2E artifacts
playwright-report/
e2e-results/

# Superpowers plans (generated implementation plans ? AI work artifacts, not project docs)
docs/superpowers/plans/
**/infra/**/.terraform/**

# Terraform: real var files + state hold secrets in plaintext — never commit
# (constraint #8: no state files / secrets in VCS; ADR-0023/ADR-0044). Only the
# secret-free *.tfvars.example templates are tracked; secrets come from TF_VAR_*
# (mapped from .env.<env>) at apply time.
infra/**/*.tfvars
!infra/**/*.tfvars.example
infra/**/*.tfvars.json
infra/**/*.tfstate
infra/**/*.tfstate.*
infra/**/*.tfplan
crash.log
crash.*.log

# Tilt pid
.tilt.pid
.tilt.log
.password

# Playwright MCP session artifacts (snapshots/console logs)
.playwright-mcp/

# CodeQL local database + SARIF (never commit scan output)
.codeql/
*.sarif

# Serena MCP per-developer project cache
.serena/

# Agent tooling state/DB artifacts (ruflo / claude-flow / agentdb / ruvector) — never commit
.claude/memory.db
.swarm/
*.rvf
*.rvf.lock
ruvector.db

# Local backup artifacts (ADR-ACT-0229) — never commit
.local-artifacts/

# persona-matrix per-persona aggregation fragments (regenerated each run)
docs/evidence/e2e/.persona-matrix-frags/
test-results/
