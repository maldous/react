{
  "name": "@platform/graphql-api-runtime",
  "version": "0.1.0",
  "private": true,
  "description": "GraphQL server runtime: schema stitching, resolver execution, DataLoader batching, and persisted-query enforcement.",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "architecture": {
    "schemaVersion": "1.0",
    "component": {
      "type": "library",
      "name": "graphql-api-runtime",
      "system": "enterprise-react-platform",
      "domain": "operations",
      "boundedContext": "graphql-server",
      "owner": "team-platform"
    },
    "lifecycle": {
      "stage": "active",
      "role": "platform",
      "class": "active.platform",
      "catalogLifecycle": "production",
      "visibility": "internal",
      "supportLevel": "standard",
      "reviewCadence": "quarterly"
    },
    "governance": {
      "decisionRefs": [
        "ADR-0001",
        "ADR-0002",
        "ADR-0003",
        "ADR-0005"
      ],
      "semverPolicy": "internal-traceable",
      "changeControl": "owner-review",
      "promotionEligible": true
    },
    "runtime": {
      "production": true,
      "testOnly": false,
      "serviceName": "graphql-api-runtime",
      "serviceNamespace": "operations",
      "deploymentEnvironments": [
        "local",
        "development",
        "staging",
        "production"
      ]
    },
    "boundaries": {
      "publicExportsOnly": true,
      "deepImportsAllowed": false,
      "allowedConsumers": [
        "application"
      ],
      "forbiddenConsumers": [
        "domain",
        "contract",
        "ui",
        "feature"
      ]
    },
    "relations": {
      "dependsOn": [
        "@platform/api-runtime",
        "@platform/contracts-graphql",
        "@platform/adapters-postgres",
        "@platform/adapters-clickhouse",
        "@platform/observability"
      ],
      "providesApis": [
        "graphql-server",
        "resolver-context",
        "dataloader-registry"
      ],
      "consumesApis": [
        "http-api-server",
        "GraphQL SDL contracts",
        "postgres-transactional-adapter",
        "clickhouse-analytics-adapter",
        "observability-core"
      ]
    },
    "tags": {
      "scope": "operations",
      "type": "library",
      "stage": "active",
      "role": "platform",
      "layer": "runtime"
    },
    "readme": {
      "generated": true,
      "summary": "GraphQL server runtime: schema stitching, resolver execution, DataLoader batching, and persisted-query enforcement.",
      "responsibilities": [
        "Mount a GraphQL endpoint on the HTTP API server",
        "Stitch and validate GraphQL schema from contract packages",
        "Provide resolver context with DataLoader instances for batched data access",
        "Enforce persisted-query and depth-limit policies"
      ],
      "nonResponsibilities": [
        "Does not define GraphQL schema contracts (owned by contracts-graphql)",
        "Does not own client-side query documents or hooks",
        "Does not implement domain business rules"
      ],
      "usage": [
        "Imported only by application packages to register the GraphQL endpoint",
        "Resolvers delegate to domain and adapter packages via injected context"
      ],
      "operationalNotes": [
        "DataLoader instances are scoped per request to avoid cache cross-contamination",
        "Persisted-query enforcement is enabled by default in non-local environments"
      ]
    }
  }
}
