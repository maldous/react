{
  "$schema": "./schema.json",
  "environmentId": "test",
  "name": "Test/CI",
  "stage": "test",
  "executor": "compose",
  "composeProject": "react-test",
  "baseUrl": "http://test.localhost",
  "apiUrl": "http://test.localhost",
  "domain": "test.localhost",
  "stagePolicy": {
    "authMode": "fixture",
    "dataPolicy": "destructive",
    "dataPreservation": "ephemeral",
    "destructiveAllowed": true,
    "teardownDefault": false,
    "cookieSecure": false
  },
  "allowedProfiles": [
    "default",
    "identity",
    "external-mocks",
    "observability",
    "web",
    "cloud-mocks"
  ],
  "allowedMocks": ["wiremock", "mock-oidc", "localstack"],
  "secretStoreProvider": "openbao",
  "adminIdentity": {
    "usernameTemplate": "sysadmin@test.localhost",
    "mode": "auto-local",
    "rotateBeforeProduction": false
  },
  "seededProviderDefaults": [
    {
      "providerKey": "postgres",
      "capability": "relational-store",
      "classification": "per-environment",
      "requiresCredential": true
    },
    {
      "providerKey": "redis",
      "capability": "cache-and-rate-limit",
      "classification": "per-environment",
      "requiresCredential": false
    },
    {
      "providerKey": "minio",
      "capability": "object-storage",
      "classification": "per-environment",
      "requiresCredential": true
    },
    {
      "providerKey": "keycloak",
      "capability": "identity-provider",
      "classification": "per-environment",
      "requiresCredential": true
    },
    {
      "providerKey": "openbao",
      "capability": "runtime-secrets",
      "classification": "per-environment",
      "requiresCredential": true
    },
    {
      "providerKey": "mailpit",
      "capability": "email-transport",
      "classification": "mock-only",
      "requiresCredential": false
    },
    {
      "providerKey": "sentry",
      "capability": "error-tracking",
      "classification": "shared-cross-environment",
      "requiresCredential": true
    }
  ],
  "runtime": {
    "WEB_HTTP_PORT": "8081",
    "PLATFORM_API_PORT": "3002",
    "MAILPIT_SMTP_PORT": "1026",
    "MAILPIT_UI_PORT": "8026",
    "OTEL_GRPC_PORT": "4322",
    "OTEL_HTTP_PORT": "4323",
    "OTEL_HEALTH_PORT": "13138",
    "LOCALSTACK_PORT": "4567",
    "PGADMIN_PORT": "5051",
    "POSTGRES_PORT": "5434",
    "REDIS_PORT": "6380",
    "WIREMOCK_PORT": "8086",
    "KEYCLOAK_PORT": "8091",
    "CLICKHOUSE_HTTP_PORT": "8125",
    "MINIO_API_PORT": "9010",
    "MINIO_CONSOLE_PORT": "9011",
    "CLICKHOUSE_NATIVE_PORT": "9003",
    "APEX_DOMAIN": "test.localhost",
    "KC_HOSTNAME": "http://test.localhost/kc",
    "APP_BASE_URL": "http://test.localhost",
    "PLATFORM_API_URL": "http://test.localhost",
    "MINIO_BROWSER_REDIRECT_URL": "http://test.localhost/minio",
    "MAILPIT_ROOT_URL": "/mailpit",
    "LOCAL_FIXTURE_SESSION": "",
    "SESSION_COOKIE_SECURE": "false",
    "COMPOSE_PROJECT": "react-test",
    "COMPOSE_PROJECT_FILTER": "react-test",
    "PLATFORM_ENV": "test",
    "GRAFANA_PORT": "3201",
    "TEMPO_HTTP_PORT": "3211",
    "LOKI_PORT": "3101",
    "ALLOY_PORT": "12346",
    "GRAFANA_ADMIN_USER": "admin",
    "LOG_LEVEL": "warn",
    "KEYCLOAK_TEST_USERNAME": "sysadmin@aldous.info",
    "CLICKHOUSE_HTTP": "http://localhost:8125",
    "KEYCLOAK_REALM": "platform-test",
    "MAILPIT_API": "http://localhost:8026/mailpit",
    "MINIO_ENDPOINT": "http://localhost:9010",
    "S3_DEFAULT_ENDPOINT": "http://localhost:9010",
    "S3_DEFAULT_BUCKET": "platform-data",
    "S3_DEFAULT_REGION": "us-east-1",
    "NODE_ENV": "test",
    "OTEL_HTTP": "http://localhost:4323",
    "POSTGRES_APP_URL": "postgresql://platform_app:platformapppassword@localhost:5434/platform",
    "POSTGRES_URL": "postgresql://platform:platformpassword@localhost:5434/platform",
    "REDIS_URL": "redis://localhost:6380",
    "SENTRY_ENABLED": "true",
    "E2E_FAILURE_ENDPOINT_ENABLED": "true",
    "SENTRY_EVENT_RETENTION_DAYS": "90",
    "MOCK_OIDC_PORT": "9081",
    "MOCK_OIDC_PUBLIC_URL": "http://localhost:9081",
    "MOCK_OIDC_INTERNAL_URL": "http://mock-oidc:8080",
    "MOCK_OIDC_KC_BROKER_BASE": "http://test.localhost/kc/realms/platform/broker"
  }
}
