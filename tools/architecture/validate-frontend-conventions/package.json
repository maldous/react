{
  "name": "@architecture/validate-frontend-conventions",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Validates SPA feature conventions: no feature-owned main landmark, no inline GraphQL, no raw /api/graphql fetch.",
  "main": "src/index.mjs",
  "exports": {
    ".": "./src/index.mjs"
  },
  "architecture": {
    "schemaVersion": "1.0",
    "component": {
      "type": "tool",
      "name": "validate-frontend-conventions",
      "system": "enterprise-react-platform",
      "domain": "architecture",
      "boundedContext": "architecture-governance",
      "owner": "team-platform"
    },
    "lifecycle": {
      "stage": "stable",
      "role": "tooling",
      "class": "stable.tooling",
      "catalogLifecycle": "production",
      "visibility": "internal",
      "supportLevel": "standard",
      "reviewCadence": "on-change"
    },
    "governance": {
      "decisionRefs": [
        "ADR-0011",
        "ADR-0019"
      ],
      "semverPolicy": "internal-traceable",
      "changeControl": "owner-review",
      "promotionEligible": false
    },
    "runtime": {
      "production": false,
      "testOnly": true,
      "serviceName": "validate-frontend-conventions",
      "serviceNamespace": "architecture",
      "deploymentEnvironments": [
        "local",
        "test"
      ]
    },
    "boundaries": {
      "publicExportsOnly": true,
      "deepImportsAllowed": false,
      "allowedConsumers": [
        "architecture"
      ],
      "forbiddenConsumers": [
