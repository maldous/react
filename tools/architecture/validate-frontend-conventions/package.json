        "frontend-conventions-validation"
      ],
      "consumesApis": []
    },
    "tags": {
      "scope": "governance",
      "type": "tool",
      "stage": "stable",
      "role": "tooling",
      "layer": "tooling"
    },
    "readme": {
      "generated": true,
      "summary": "Validates SPA feature conventions for the canonical UI baseline.",
      "responsibilities": [
        "Fail the build when feature code renders the main#main-content landmark",
        "Fail the build on inline GraphQL operation strings in feature code",
        "Fail the build on raw /api/graphql fetch outside the approved browser client"
      ],
      "nonResponsibilities": [
        "Does not validate import boundaries (validate-source-imports owns that)",
        "Does not validate i18n keys (validate-i18n owns that)"
      ],
      "usage": [
        "node tools/architecture/validate-frontend-conventions/src/index.mjs"
      ],
      "operationalNotes": [
        "Run npm run frontend:conventions; enforced via test:architecture and make check (ADR-ACT-0203)."
      ]
    }
  },
  "scripts": {
    "test": "node --test tests/"
  }
}
