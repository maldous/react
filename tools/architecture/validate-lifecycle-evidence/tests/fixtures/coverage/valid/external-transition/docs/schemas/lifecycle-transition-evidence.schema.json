{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://architecture.local/schemas/lifecycle-transition-evidence.schema.json",
  "title": "Lifecycle Transition Evidence Bundle",
  "description": "Evidence bundle for governed package lifecycle transitions.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "bundle",
    "package",
    "transition",
    "governance",
    "risk",
    "testing",
    "impact",
    "rollback",
    "sourceMetadataSnapshot",
    "reportReferences"
  ],
  "properties": {
    "schemaVersion": {
      "const": "1.0"
    },
    "bundle": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "createdAt",
        "createdBy",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "createdBy": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "draft",
            "reviewed",
            "approved",
            "rejected"
          ]
        }
      }
    },
    "package": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "path",
        "owner"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "transition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fromClass",
        "toClass",
        "reason",
        "requestedAt"
      ],
      "properties": {
        "fromClass": {
          "type": "string",
          "pattern": "^[a-z]+\\.[a-z]+$"
        },
        "toClass": {
          "type": "string",
          "pattern": "^[a-z]+\\.[a-z]+$"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "requestedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "governance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decisionRefs",
        "reviewers",
        "approvers"
      ],
      "properties": {
        "decisionRefs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^ADR-\\d{4}$"
          }
        },
        "reviewers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/personEvidence"
          }
        },
        "approvers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/personEvidence"
          }
        }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "level",
        "assessment",
        "mitigations"
      ],
      "properties": {
        "level": {
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ]
        },
        "assessment": {
          "type": "string",
          "minLength": 1
        },
        "mitigations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "testing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "evidence"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/fileReference"
          }
        }
      }
    },
    "impact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtimeImpact",
        "consumerImpact"
      ],
      "properties": {
        "runtimeImpact": {
          "type": "string"
        },
        "consumerImpact": {
          "type": "string"
        }
      }
    },
    "rollback": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strategy",
        "notes"
      ],
      "properties": {
        "strategy": {
          "type": "string",
          "minLength": 1
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "sourceMetadataSnapshot": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "packageJsonPath",
        "architecture"
      ],
      "properties": {
        "packageJsonPath": {
          "type": "string",
          "minLength": 1
        },
        "architecture": {
          "type": "object"
        }
      }
    },
    "reportReferences": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/fileReference"
      }
    }
  },
  "$defs": {
    "personEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "role",
        "reviewedAt"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "minLength": 1
        },
        "reviewedAt": {
          "type": "string",
          "format": "date-time"
        },
        "evidenceRef": {
          "type": "string"
        }
      }
    },
    "fileReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "description"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
