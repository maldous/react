{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "allowJs": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node", "@playwright/test"],
    "baseUrl": ".",
    "paths": {
      "@platform/ui-design-system": ["../../packages/ui-design-system/src/index.ts"]
    }
  },
  "include": ["src", "playwright", "tests"]
}
