# Local development environment variables for Docker Compose.
# Copy to .env and fill in values. Never commit .env to version control.

# ---------------------------------------------------------------------------
# PostgreSQL (default profile)
# ---------------------------------------------------------------------------
POSTGRES_USER=platform
POSTGRES_PASSWORD=platformpassword
POSTGRES_DB=platform

# ---------------------------------------------------------------------------
# Redis (default profile)
# ---------------------------------------------------------------------------
# No required env vars; uses default config.

# ---------------------------------------------------------------------------
# ClickHouse (default profile)
# ---------------------------------------------------------------------------
CLICKHOUSE_USER=platform
CLICKHOUSE_PASSWORD=clickhousepassword
CLICKHOUSE_DB=platform

# ---------------------------------------------------------------------------
# MinIO (default profile)
# ---------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=miniopassword

# ---------------------------------------------------------------------------
# SonarQube (quality profile)
# Default login: admin / admin — change on first browser login.
# Generate a token at http://localhost:9003/account/security and set:
#   SONAR_TOKEN=<your-token>   (used by sonar-scanner CLI)
# ---------------------------------------------------------------------------
SONAR_DB_USER=sonar
SONAR_DB_PASSWORD=sonarpassword
SONAR_DB_NAME=sonar
SONAR_TOKEN=

# ---------------------------------------------------------------------------
# Keycloak (identity profile)
# Default admin login: admin / admin
# ---------------------------------------------------------------------------
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=keycloakpassword
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ---------------------------------------------------------------------------
# LocalStack (cloud-mocks profile)
# ---------------------------------------------------------------------------
LOCALSTACK_SERVICES=s3,sqs,sns,secretsmanager
LOCALSTACK_DEBUG=0

# ---------------------------------------------------------------------------
# Sentry (sentry profile)
# Generate SENTRY_SECRET_KEY with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# After first start, create admin user:
#   docker exec -it react-platform-sentry-web-1 sentry createuser \
#     --email admin@example.local --password admin --superuser
# ---------------------------------------------------------------------------
SENTRY_SECRET_KEY=change-this-to-a-real-secret-key
SENTRY_DB_USER=sentry
SENTRY_DB_PASSWORD=sentrypassword
SENTRY_DB_NAME=sentry

# ---------------------------------------------------------------------------
# Application runtime (used by platform adapters)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://platform:platformpassword@localhost:5433/platform
REDIS_URL=redis://localhost:6379
CLICKHOUSE_URL=http://platform:clickhousepassword@localhost:8124
MINIO_ENDPOINT=localhost:9000
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
SENTRY_DSN=
