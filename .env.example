# .env.example — Reference for all configurable environment variables.
# Copy to .env.dev / .env.test / .env.staging / .env.prod as appropriate.
# These files are gitignored. Never commit files containing real credentials.

# ── Service credentials (gitignored, set locally) ──────────────────────────
POSTGRES_USER=platform
POSTGRES_PASSWORD=<set locally>
POSTGRES_DB=platform
CLICKHOUSE_USER=platform
CLICKHOUSE_PASSWORD=<set locally>
CLICKHOUSE_DB=platform
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=<set locally>
SONAR_DB_USER=sonar
SONAR_DB_PASSWORD=<set locally>
SONAR_DB_NAME=sonar
SONAR_PROJECT_KEY=maldous-react
SONAR_TOKEN=<sonarqube analysis token>
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=<set locally>
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=<set locally>
LOCALSTACK_SERVICES=s3,sqs,sns,secretsmanager
LOCALSTACK_DEBUG=0
SENTRY_SECRET_KEY=<generate: python3 -c "import secrets; print(secrets.token_hex(32))">
SENTRY_DB_USER=sentry
SENTRY_DB_PASSWORD=<set locally>
SENTRY_DB_NAME=sentry
CADDY_INTERNAL_SECRET=<generate: python3 -c "import secrets; print(secrets.token_hex(32))">
KEYCLOAK_CLIENT_SECRET=<set locally>
KEYCLOAK_TEST_USERNAME=sysadmin@aldous.info
KEYCLOAK_TEST_PASSWORD=password   # fixture user password (fixture_user_password in tfvars)

# ── Host port mapping (all unique across envs — +1 per env unless noted) ───
# Service              dev    test   staging  prod
# WEB_HTTP_PORT       8080   8081      82      83   (low ports intentional for staging/prod)
WEB_HTTP_PORT=8080
# PLATFORM_API_PORT   3001   3002    3003    3004
PLATFORM_API_PORT=3001
# MAILPIT_SMTP_PORT   1025   1026    1027    1028
MAILPIT_SMTP_PORT=1025
# MAILPIT_UI_PORT     8025   8026    8027    8028
MAILPIT_UI_PORT=8025
# OTEL_GRPC_PORT      4317   4322    4327    4332   (+5)
OTEL_GRPC_PORT=4317
# OTEL_HTTP_PORT      4318   4323    4328    4333   (+5)
OTEL_HTTP_PORT=4318
# OTEL_HEALTH_PORT   13133  13138   13143   13148   (+5)
OTEL_HEALTH_PORT=13133
# LOCALSTACK_PORT     4566   4567    4568    4569
LOCALSTACK_PORT=4566
# PGADMIN_PORT        5050   5051    5052    5053
PGADMIN_PORT=5050
# POSTGRES_PORT       5433   5434    5435    5436
POSTGRES_PORT=5433
# REDIS_PORT          6379   6380    6381    6382
REDIS_PORT=6379
# WIREMOCK_PORT       8085   8086    8087    8088
WIREMOCK_PORT=8085
# KEYCLOAK_PORT       8090   8091    8092    8093
KEYCLOAK_PORT=8090
# CLICKHOUSE_HTTP     8124   8125    8126    8127
CLICKHOUSE_HTTP_PORT=8124
# MINIO_API_PORT      9000   9010    9020    9030   (+10)
MINIO_API_PORT=9000
# MINIO_CONSOLE_PORT  9001   9011    9021    9031   (+10)
MINIO_CONSOLE_PORT=9001
# CLICKHOUSE_NATIVE   9002   9003    9004    9005
CLICKHOUSE_NATIVE_PORT=9002
# SENTRY — shared instance config lives in .env.sentry (copy from .env.sentry.example)
# Each environment sets SENTRY_DSN and SENTRY_ENABLED to point at the shared instance.
# SENTRY_DSN is obtained after first sentry-up by creating a project in the Sentry UI.
SENTRY_DSN=
SENTRY_ENABLED=false
SENTRY_EVENT_RETENTION_DAYS=90

# SONAR_PORT          9064   9065    9066    9067
SONAR_PORT=9064

# ── Domain configuration ───────────────────────────────────────────────────
APEX_DOMAIN=dev.localhost
KC_HOSTNAME=http://dev.localhost/kc
APP_BASE_URL=http://dev.localhost:8080
PLATFORM_API_URL=http://dev.localhost:8080
MINIO_BROWSER_REDIRECT_URL=http://dev.localhost/minio
MAILPIT_ROOT_URL=/mailpit
SONAR_HOST_URL=http://localhost:9064

# ── Session / auth ─────────────────────────────────────────────────────────
LOCAL_FIXTURE_SESSION=
SESSION_COOKIE_SECURE=false

# AES-256-GCM key for session token encryption (32 bytes / 64 hex chars).
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# TENANT_SECRET_ENCRYPTION_KEY=
