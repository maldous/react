# Local development environment variables for Docker Compose.
# Copy to .env and fill in values. Never commit .env to version control.

# ---------------------------------------------------------------------------
# Host port overrides (optional — defaults match compose.yaml)
# Developers sharing a machine with conflicting services may override these.
# ---------------------------------------------------------------------------
POSTGRES_PORT=5433
REDIS_PORT=6379
CLICKHOUSE_HTTP_PORT=8124
CLICKHOUSE_NATIVE_PORT=9002
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
OTEL_HEALTH_PORT=13133
SONAR_PORT=9003
KEYCLOAK_PORT=8090
LOCALSTACK_PORT=4566
SENTRY_PORT=9010

# ---------------------------------------------------------------------------
# PostgreSQL (default profile)
# ---------------------------------------------------------------------------
POSTGRES_USER=platform
POSTGRES_PASSWORD=platformpassword
POSTGRES_DB=platform

# ---------------------------------------------------------------------------
# Redis (default profile)
# ---------------------------------------------------------------------------
# No required env vars; uses default config.

# ---------------------------------------------------------------------------
# ClickHouse (default profile)
# ---------------------------------------------------------------------------
CLICKHOUSE_USER=platform
CLICKHOUSE_PASSWORD=clickhousepassword
CLICKHOUSE_DB=platform

# ---------------------------------------------------------------------------
# MinIO (default profile)
# ---------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=miniopassword

# ---------------------------------------------------------------------------
# SonarQube (quality profile)
# Default login: admin / admin — change on first browser login.
# Generate a token at http://localhost:9003/account/security and set:
#   SONAR_HOST_URL=http://localhost:9003
SONAR_PROJECT_KEY=maldous-react
SONAR_TOKEN=<your-token>   (used by sonar-scanner CLI)
# ---------------------------------------------------------------------------
SONAR_DB_USER=sonar
SONAR_DB_PASSWORD=sonarpassword
SONAR_DB_NAME=sonar
SONAR_HOST_URL=http://localhost:9003
SONAR_PROJECT_KEY=maldous-react
SONAR_TOKEN=

# ---------------------------------------------------------------------------
# Keycloak (identity profile)
# Default admin login: admin / admin
# ---------------------------------------------------------------------------
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=keycloakpassword
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ---------------------------------------------------------------------------
# LocalStack (cloud-mocks profile)
# ---------------------------------------------------------------------------
LOCALSTACK_SERVICES=s3,sqs,sns,secretsmanager
LOCALSTACK_DEBUG=0

# ---------------------------------------------------------------------------
# Sentry (sentry profile)
# Generate SENTRY_SECRET_KEY with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# After first start, create admin user:
#   docker exec -it react-platform-sentry-web-1 sentry createuser \
#     --email admin@example.local --password admin --superuser
# ---------------------------------------------------------------------------
SENTRY_SECRET_KEY=change-this-to-a-real-secret-key
SENTRY_DB_USER=sentry
SENTRY_DB_PASSWORD=sentrypassword
SENTRY_DB_NAME=sentry

# ---------------------------------------------------------------------------
# Application runtime (used by platform adapters)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://platform:platformpassword@localhost:5433/platform
REDIS_URL=redis://localhost:6379
CLICKHOUSE_URL=http://platform:clickhousepassword@localhost:8124
MINIO_ENDPOINT=localhost:9000
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
SENTRY_DSN=

# ---------------------------------------------------------------------------
# Web profile — docker compose --profile web up -d
# Delivers the full app on :80 without system services.
# ---------------------------------------------------------------------------
# External-mocks profile — docker compose --profile external-mocks up -d wiremock
# WireMock host port; container always listens on 8080.
# 8090 is Keycloak; 8089 is the platform default for WireMock.
WIREMOCK_PORT=8089

# ---------------------------------------------------------------------------
# Port for the Caddy web container (default 80)
WEB_HTTP_PORT=80

# Fixture session for demo mode (tenant-admin shows the full app).
# Set to empty string to require real Keycloak login (ADR-ACT-0119).
# Values: tenant-admin | viewer | no-membership | (empty = login required)
# Leave empty for real Keycloak login. Set to tenant-admin/viewer/no-membership for fixture dev mode.
LOCAL_FIXTURE_SESSION=

# Session cookie Secure flag.
# false (default) — local Compose HTTP; browser accepts cookies over http://localhost.
# true            — set when behind HTTPS/Cloudflare (e.g. aldous.info production).
SESSION_COOKIE_SECURE=false

# Public base URLs — used by platform-api for OAuth callbacks and redirects.
# Set to http://aldous.info for local Caddy-based testing (web profile).
# Requires one-time /etc/hosts entry: 127.0.0.1 aldous.info
# Set to https://aldous.info for production (Cloudflare-terminated).
APP_BASE_URL=http://aldous.info
PLATFORM_API_URL=http://aldous.info

# Keycloak BFF client secret — required for real Keycloak login (ADR-ACT-0119).
# Never commit a real value. Leave empty for fixture-session demo mode.
KEYCLOAK_CLIENT_SECRET=

# Caddy forward auth internal secret — shared between Caddy and platform-api.
# Prevents external clients from calling /internal/auth/forward directly.
# Generate with: openssl rand -hex 32
# Must be set in production. Leave empty for local dev (check disabled when empty).
CADDY_INTERNAL_SECRET=

# Apex domain for FQDN-based tenant routing (ADR-0029).
# platform-api uses this to validate host headers and resolve tenant slugs.
APEX_DOMAIN=aldous.info

# Mailpit path prefix (serves UI at /mailpit/ when proxied via Caddy)
MAILPIT_ROOT_URL=/mailpit

# ---------------------------------------------------------------------------
# Real-auth E2E test credentials (playwright.real-auth.config.ts)
# Never commit real values. Set in your local shell or .env (gitignored).
# The sysadmin@aldous.info user is provisioned by make keycloak-provision.
# Default local dev password is "password" (from infra/env/local/local.tfvars).
# ---------------------------------------------------------------------------
KEYCLOAK_TEST_USERNAME=sysadmin@aldous.info
# Local dev default — matches fixture_user_password in infra/env/local/local.tfvars
KEYCLOAK_TEST_PASSWORD=password

