# .env.example — Reference for all configurable environment variables.
# Copy to .env.dev / .env.test / .env.staging / .env.prod as appropriate.
# These files are gitignored. Never commit files containing real credentials.

# ── Service credentials (gitignored, set locally) ──────────────────────────
POSTGRES_USER=platform
POSTGRES_PASSWORD=<set locally>
POSTGRES_DB=platform
CLICKHOUSE_USER=platform
CLICKHOUSE_PASSWORD=<set locally>
CLICKHOUSE_DB=platform
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=<set locally>
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=<set locally>
KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=<set locally>
LOCALSTACK_SERVICES=s3,sqs,sns,secretsmanager
LOCALSTACK_DEBUG=0
SENTRY_SECRET_KEY=<generate: python3 -c "import secrets; print(secrets.token_hex(32))">
SENTRY_DB_USER=sentry
SENTRY_DB_PASSWORD=<set locally>
SENTRY_DB_NAME=sentry
SENTRY_DSN=
SENTRY_ENABLED=false
CADDY_INTERNAL_SECRET=<generate: python3 -c "import secrets; print(secrets.token_hex(32))">
KEYCLOAK_CLIENT_SECRET=<set locally>

# ── Derived connection strings ─────────────────────────────────────────────
DATABASE_URL=postgresql://platform:platformpassword@localhost:5433/platform
CLICKHOUSE_URL=http://platform:clickhousepassword@localhost:8124
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ── Host port mapping (all unique across envs — +1 per env unless noted) ───
# Service              dev    test   staging  prod
# WEB_HTTP_PORT       8080   8081      82      83   (low ports intentional for staging/prod)
WEB_HTTP_PORT=8080
# PLATFORM_API_PORT   3001   3002    3003    3004
PLATFORM_API_PORT=3001
# MAILPIT_SMTP_PORT   1025   1026    1027    1028
MAILPIT_SMTP_PORT=1025
# MAILPIT_UI_PORT     8025   8026    8027    8028
MAILPIT_UI_PORT=8025
# OTEL_GRPC_PORT      4317   4322    4327    4332   (+5)
OTEL_GRPC_PORT=4317
# OTEL_HTTP_PORT      4318   4323    4328    4333   (+5)
OTEL_HTTP_PORT=4318
# OTEL_HEALTH_PORT   13133  13138   13143   13148   (+5)
OTEL_HEALTH_PORT=13133
# LOCALSTACK_PORT     4566   4567    4568    4569
LOCALSTACK_PORT=4566
# PGADMIN_PORT        5050   5051    5052    5053
PGADMIN_PORT=5050
# POSTGRES_PORT       5433   5434    5435    5436
POSTGRES_PORT=5433
# REDIS_PORT          6379   6380    6381    6382
REDIS_PORT=6379
# WIREMOCK_PORT       8085   8086    8087    8088
WIREMOCK_PORT=8085
# KEYCLOAK_PORT       8090   8091    8092    8093
KEYCLOAK_PORT=8090
# CLICKHOUSE_HTTP     8124   8125    8126    8127
CLICKHOUSE_HTTP_PORT=8124
# MINIO_API_PORT      9000   9010    9020    9030   (+10)
MINIO_API_PORT=9000
# MINIO_CONSOLE_PORT  9001   9011    9021    9031   (+10)
MINIO_CONSOLE_PORT=9001
# CLICKHOUSE_NATIVE   9002   9003    9004    9005
CLICKHOUSE_NATIVE_PORT=9002
# Sonar host port lives in .env.sonar (shared instance, single port — default 9064).

# ── Domain configuration ───────────────────────────────────────────────────
APEX_DOMAIN=dev.localhost
KC_HOSTNAME=http://dev.localhost/kc
APP_BASE_URL=http://dev.localhost:8080
PLATFORM_API_URL=http://dev.localhost:8080
MINIO_BROWSER_REDIRECT_URL=http://dev.localhost/minio
MAILPIT_ROOT_URL=/mailpit

# ── Session / auth ─────────────────────────────────────────────────────────
LOCAL_FIXTURE_SESSION=
SESSION_COOKIE_SECURE=false

# ── Compose project isolation ──────────────────────────────────────────────
COMPOSE_PROJECT=react
COMPOSE_PROJECT_FILTER=react

# ── Observability (Loki + Grafana + Alloy) ─────────────────────────────────
PLATFORM_ENV=development
GRAFANA_PORT=3200
LOKI_PORT=3100
# Loki base URL for the admin log search API (ADR-0035, ADR-ACT-0194).
# Optional: leave unset and it is derived as http://localhost:${LOKI_PORT}, so each
# environment (dev 3100 / test 3101 / staging 3102 / prod 3103) is unique via its own
# LOKI_PORT. The compose platform-api container overrides this with the internal
# http://loki:3100. Set explicitly only to point at a non-default Loki.
# LOKI_URL=http://localhost:3100
ALLOY_PORT=12345
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
LOG_LEVEL=debug

# ── Explicit per-environment values (all env files share identical key sets) ─
CLICKHOUSE_HTTP=http://localhost:8124
KEYCLOAK_REALM=platform
KEYCLOAK_TEST_USERNAME=sysadmin@aldous.info
KEYCLOAK_TEST_PASSWORD=password
MAILPIT_API=http://localhost:8025/mailpit
MINIO_ENDPOINT=http://localhost:9000
NODE_ENV=development
OTEL_HTTP=http://localhost:4318
POSTGRES_APP_URL=postgresql://platform_app:platformapppassword@localhost:5433/platform
POSTGRES_URL=postgresql://platform:platformpassword@localhost:5433/platform
REDIS_URL=redis://localhost:6379
SENTRY_EVENT_RETENTION_DAYS=90

# AES-256-GCM key for session token encryption (32 bytes / 64 hex chars).
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
TENANT_SECRET_ENCRYPTION_KEY=

# ── Sentry shared instance — config in .env.sentry (copy from .env.sentry.example) ─
# SENTRY_URL_PREFIX — set in .env.sentry; local dev uses http://localhost:5173/sentry

# ── Sonar shared instance  — config in .env.sonar (copy from .env.sonar.example) ──
# SONAR_HOST_URL=http://localhost:9064/sonar  SONAR_PROJECT_KEY=maldous-react
# Single SonarQube instance (react-sonar project) shared across dev/test/staging/prod.
# Start with: make sonar-up
